generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model SystemSettings {
  id                       String                   @id @default("singleton")
  tenantId                 String                   @default("org_pahlajani_001")
  clinicName               String                   @default("Pahlajani's Women's Hospital")
  brandColor               String                   @default("#0f172a")
  aiRoutingEnabled         Boolean                  @default(false)
  tataVirtualNumber        String?
  updatedAt                DateTime                 @updatedAt
  leadDistributionStrategy LeadDistributionStrategy @default(MANUAL)
  integrations             Json?                    @default("{}")

  @@map("system_settings")
}

model Branch {
  id        String   @id @default(cuid())
  tenantId  String   @default("org_pahlajani_001")
  name      String
  city      String
  isHQ      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isActive  Boolean  @default(true)
  leads     Lead[]

  @@map("branches")
}

model User {
  id                       String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId                 String          @default("org_pahlajani_001")
  email                    String          @unique
  emailVerified            DateTime?
  name                     String?
  image                    String?
  role                     UserRole        @default(AGENT)
  isActive                 Boolean         @default(true)
  platformConsentGiven     Boolean         @default(false)
  platformConsentTimestamp DateTime?
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt
  isOnline                 Boolean         @default(false)
  activityLogs             ActivityLog[]
  ownedLeads               Lead[]          @relation("LeadOwner")
  accounts                 Account[]
  sessions                 Session[]
  Authenticator            Authenticator[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  tenantId          String  @default("org_pahlajani_001")
  userId            String  @db.Uuid
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  tenantId     String   @default("org_pahlajani_001")
  sessionToken String   @unique
  userId       String   @db.Uuid
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Authenticator {
  credentialID         String  @unique
  userId               String  @db.Uuid
  providerAccountId    String
  credentialPublicKey  String
  counter              Int
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, credentialID])
  @@map("authenticators")
}

model Lead {
  id                  String            @id @default(cuid())
  tenantId            String            @default("org_pahlajani_001")
  name                String
  email               String?
  phone               String?
  whatsappNumber      String?
  source              LeadSource        @default(WEBSITE_FORM)
  status              LeadStatus        @default(RAW)
  intent              LeadIntent        @default(UNSCORED)
  metadata            Json?
  aiScore             Int?
  aiScoredAt          DateTime?
  aiNotes             String?
  assignedAt          DateTime?
  consentFlag         Boolean           @default(false)
  consentTimestamp    DateTime?
  consentMethod       String?
  dataRetentionExpiry DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  branchId            String?
  isAutoAssigned      Boolean           @default(false)
  category            TreatmentCategory @default(OTHER)
  ownerId             String?           @db.Uuid
  aiChatStatus        AiChatStatus      @default(AGENTX_ACTIVE)
  isEscalated         Boolean           @default(false)
  activityLogs        ActivityLog[]
  autoNurtureQueue    AutoNurtureQueue?
  callLogs            CallLog[]
  branch              Branch?           @relation(fields: [branchId], references: [id])
  owner               User?             @relation("LeadOwner", fields: [ownerId], references: [id])

  @@index([branchId])
  @@index([ownerId])
  @@index([category])
  @@map("leads")
}

model AutoNurtureQueue {
  id           String    @id @default(cuid())
  tenantId     String    @default("org_pahlajani_001")
  leadId       String    @unique
  scheduledAt  DateTime  @default(now())
  nextFollowUp DateTime?
  attempt      Int       @default(0)
  isResolved   Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lead         Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([isResolved])
  @@map("auto_nurture_queue")
}

model ActivityLog {
  id          String   @id @default(cuid())
  tenantId    String   @default("org_pahlajani_001")
  leadId      String?
  userId      String?  @db.Uuid
  action      String
  description String?
  metadata    Json?
  createdAt   DateTime @default(now())
  lead        Lead?    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user        User?    @relation(fields: [userId], references: [id])

  @@map("activity_logs")
}

model CallLog {
  id           String        @id @default(cuid())
  tenantId     String        @default("org_pahlajani_001")
  leadId       String?
  direction    CallDirection
  status       CallStatus    @default(CONNECTED)
  duration     Int           @default(0)
  recordingUrl String?
  isQualified  Boolean       @default(false)
  isAiHandled  Boolean       @default(false)
  callerId     String
  receiverId   String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  lead         Lead?         @relation(fields: [leadId], references: [id])

  @@index([leadId])
  @@map("call_logs")
}

enum Industry {
  HEALTHCARE
  EDUCATION
  REAL_ESTATE
  FINANCE
  OTHER
}

enum LeadDistributionStrategy {
  ROUND_ROBIN
  MANUAL
}

enum OrgPlan {
  STARTER
  GROWTH
  ENTERPRISE
}

enum UserRole {
  SUPER_ADMIN
  ORG_ADMIN
  MANAGER
  AGENT
  VIEWER
  DOCTOR
  COUNSELOR
  TELESALES
  FIELD_SALES
}

enum LeadSource {
  META_ADS
  GOOGLE_ADS
  WEBSITE_FORM
  WHATSAPP
  WALK_IN
  REFERRAL
  OTHER
  INSTAGRAM_ADS
  TIKTOK_ADS
  LINKEDIN_ADS
  MANUAL_ENTRY
  BULK_IMPORT
  META_MESSAGING
}

enum LeadStatus {
  RAW
  QUALIFIED
  CONTACTED
  APPOINTMENT_FIXED
  VISITED
  WON
  LOST
}

enum LeadIntent {
  HOT
  WARM
  COLD
  UNSCORED
}

enum TreatmentCategory {
  MATERNITY
  GYNECOLOGY
  INFERTILITY
  OTHER
  PEDIATRICS
}

enum CallDirection {
  INBOUND
  OUTBOUND
}

enum CallStatus {
  CONNECTED
  MISSED
  BUSY
  VOICEMAIL
  AI_HANDLED
}

enum AiChatStatus {
  AGENTX_ACTIVE
  HUMAN_OVERRIDE
}
