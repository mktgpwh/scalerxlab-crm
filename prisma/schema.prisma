generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters", "views"]
}

datasource db {
  provider = "postgresql"
}

model SystemSettings {
  id                       String                   @id @default("singleton")
  clinicName               String                   @default("Pahlajani's Women's Hospital")
  brandColor               String                   @default("#0f172a")
  aiRoutingEnabled         Boolean                  @default(false)
  tataVirtualNumber        String?
  updatedAt                DateTime                 @updatedAt
  leadDistributionStrategy LeadDistributionStrategy @default(MANUAL)
  integrations             Json?                    @default("{}")
  tenantId                 String                   @default("org_pahlajani_001")

  @@map("system_settings")
}

model Branch {
  id        String   @id @default(cuid())
  name      String
  city      String
  isHQ      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isActive  Boolean  @default(true)
  tenantId  String   @default("org_pahlajani_001")
  leads     Lead[]
  users     User[]

  @@map("branches")
}

model User {
  id                       String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                    String          @unique
  name                     String?
  role                     UserRole        @default(SALES_USER)
  isActive                 Boolean         @default(true)
  platformConsentGiven     Boolean         @default(false)
  platformConsentTimestamp DateTime?
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt
  isOnline                 Boolean         @default(false)
  emailVerified            DateTime?
  image                    String?
  tenantId                 String          @default("org_pahlajani_001")
  branchId                 String?
  phone                    String?
  password                 String?
  accounts                 Account[]
  activityLogs             ActivityLog[]
  Authenticator            Authenticator[]
  ownedLeads               Lead[]          @relation("LeadOwner")
  calls                    CallLog[]       @relation("AgentCalls")
  sessions                 Session[]
  branch                   Branch?         @relation(fields: [branchId], references: [id])

  @@index([branchId])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  tenantId          String  @default("org_pahlajani_001")
  userId            String  @db.Uuid
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  tenantId     String   @default("org_pahlajani_001")
  sessionToken String   @unique
  userId       String   @db.Uuid
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Authenticator {
  credentialID         String  @unique
  userId               String  @db.Uuid
  providerAccountId    String
  credentialPublicKey  String
  counter              Int
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?
  user                 User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, credentialID])
  @@map("authenticators")
}

model Lead {
  id                    String            @id @default(cuid())
  name                  String
  email                 String?
  phone                 String?
  whatsappNumber        String?
  source                LeadSource        @default(WEBSITE_FORM)
  status                LeadStatus        @default(RAW)
  intent                LeadIntent        @default(UNSCORED)
  metadata              Json?
  aiScore               Int?
  aiScoredAt            DateTime?
  aiNotes               String?
  assignedAt            DateTime?
  consentFlag           Boolean           @default(false)
  consentTimestamp      DateTime?
  consentMethod         String?
  dataRetentionExpiry   DateTime?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  branchId              String?
  isAutoAssigned        Boolean           @default(false)
  category              TreatmentCategory @default(OTHER)
  ownerId               String?           @db.Uuid
  aiChatStatus          AiChatStatus      @default(AGENTX_ACTIVE)
  isEscalated           Boolean           @default(false)
  tenantId              String            @default("org_pahlajani_001")
  aiLeadScore           String?
  aiSuggestedDepartment String?
  isUnderAITriage       Boolean           @default(false)
  activityLogs          ActivityLog[]
  autoNurtureQueue      AutoNurtureQueue?
  callLogs              CallLog[]
  invoices              Invoice[]
  branch                Branch?           @relation(fields: [branchId], references: [id])
  owner                 User?             @relation("LeadOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  @@index([branchId])
  @@index([ownerId])
  @@index([category])
  @@index([status])
  @@index([createdAt])
  @@index([intent])
  @@map("leads")
}

model AutoNurtureQueue {
  id           String    @id @default(cuid())
  leadId       String    @unique
  scheduledAt  DateTime  @default(now())
  nextFollowUp DateTime?
  attempt      Int       @default(0)
  isResolved   Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  tenantId     String    @default("org_pahlajani_001")
  lead         Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([isResolved])
  @@map("auto_nurture_queue")
}

model ActivityLog {
  id          String   @id @default(cuid())
  leadId      String?
  userId      String?  @db.Uuid
  action      String
  description String?
  metadata    Json?
  createdAt   DateTime @default(now())
  tenantId    String   @default("org_pahlajani_001")
  lead        Lead?    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user        User?    @relation(fields: [userId], references: [id])

  @@map("activity_logs")
}

model CallLog {
  id           String        @id @default(cuid())
  leadId       String?
  agentId      String?       @db.Uuid
  tataCallId   String?       @unique
  direction    CallDirection
  status       CallStatus    @default(CONNECTED)
  duration     Int           @default(0)
  recordingUrl String?
  isQualified  Boolean       @default(false)
  isAiHandled  Boolean       @default(false)
  metadata     Json?
  callerId     String
  receiverId   String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  tenantId     String        @default("org_pahlajani_001")
  lead         Lead?         @relation(fields: [leadId], references: [id])
  agent        User?         @relation("AgentCalls", fields: [agentId], references: [id])

  @@index([leadId])
  @@index([agentId])
  @@map("call_logs")
}

model Invoice {
  id             String        @id @default(cuid())
  tenantId       String        @default("org_pahlajani_001")
  leadId         String
  invoiceNumber  String        @unique
  department     BillingDept
  subTotal       Float
  tax            Float         @default(0)
  totalAmount    Float
  status         InvoiceStatus @default(UNPAID)
  paymentLinkId  String?
  paymentLinkUrl String?
  issuedAt       DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  createdBy      String?       @db.Uuid
  items          InvoiceItem[]
  lead           Lead          @relation(fields: [leadId], references: [id])
  payments       Payment[]

  @@index([leadId])
  @@index([invoiceNumber])
  @@map("invoices")
}

model InvoiceItem {
  id        String  @id @default(cuid())
  invoiceId String
  itemName  String
  quantity  Int     @default(1)
  unitPrice Float
  tax       Float   @default(0)
  total     Float
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_items")
}

model Payment {
  id               String      @id @default(cuid())
  tenantId         String      @default("org_pahlajani_001")
  invoiceId        String
  amount           Float
  paymentMode      PaymentMode
  upiTransactionId String?     @unique
  externalId       String?
  createdAt        DateTime    @default(now())
  createdBy        String?     @db.Uuid
  invoice          Invoice     @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
  @@map("payments")
}

view DailyRevenueSummary {
  day          DateTime    @db.Timestamp(6)
  department   BillingDept
  tenantId     String
  totalRevenue Float

  @@unique([day, department, tenantId])
}

view LeadConversionStats {
  source         LeadSource
  tenantId       String
  rawCount       Int
  wonCount       Int
  conversionRate Float

  @@unique([source, tenantId])
}

view SourcePerformance {
  source      LeadSource
  tenantId    String
  totalBilled Float

  @@unique([source, tenantId])
}

enum Industry {
  HEALTHCARE
  EDUCATION
  REAL_ESTATE
  FINANCE
  OTHER
}

enum LeadDistributionStrategy {
  ROUND_ROBIN
  MANUAL
}

enum OrgPlan {
  STARTER
  GROWTH
  ENTERPRISE
}

enum UserRole {
  SUPER_ADMIN
  SALES_ADMIN
  SALES_USER
  FRONT_DESK
  COUNSELLOR
  FIELD_SALES
}

enum LeadSource {
  META_ADS
  GOOGLE_ADS
  WEBSITE_FORM
  WHATSAPP
  WALK_IN
  REFERRAL
  OTHER
  INSTAGRAM_ADS
  TIKTOK_ADS
  LINKEDIN_ADS
  MANUAL_ENTRY
  BULK_IMPORT
  META_MESSAGING
}

enum LeadStatus {
  RAW
  QUALIFIED
  CONTACTED
  APPOINTMENT_FIXED
  VISITED
  WON
  LOST
}

enum LeadIntent {
  HOT
  WARM
  COLD
  UNSCORED
}

enum TreatmentCategory {
  MATERNITY
  GYNECOLOGY
  INFERTILITY
  OTHER
  PEDIATRICS
}

enum CallDirection {
  INBOUND
  OUTBOUND
}

enum CallStatus {
  CONNECTED
  MISSED
  BUSY
  VOICEMAIL
  AI_HANDLED
  REJECTED
  FAILED
  CANCELLED
}

enum AiChatStatus {
  AGENTX_ACTIVE
  HUMAN_OVERRIDE
}

enum BillingDept {
  OPD
  IPD
  PHARMACY
  ULTRASOUND
  LAB
}

enum InvoiceStatus {
  UNPAID
  PARTIAL
  PAID
  CANCELLED
}

enum PaymentMode {
  CASH
  UPI
  CARD
  INSURANCE
}
