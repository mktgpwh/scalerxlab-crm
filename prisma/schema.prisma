generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
}

model SystemSettings {
  id                String   @id @default("singleton")
  clinicName        String   @default("Pahlajani's Women's Hospital")
  brandColor        String   @default("#0f172a")
  aiRoutingEnabled  Boolean  @default(false)
  leadDistributionStrategy LeadDistributionStrategy @default(MANUAL)
  tataVirtualNumber String?
  integrations      Json?    @default("{}")
  updatedAt         DateTime @updatedAt

  @@map("system_settings")
}

model Branch {
  id        String   @id @default(cuid())
  name      String
  city      String
  isHQ      Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  leads     Lead[]

  @@map("branches")
}

model User {
  id                       String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                    String        @unique
  name                     String?
  avatarUrl                String?
  role                     UserRole      @default(AGENT)
  isActive                 Boolean       @default(true)
  isOnline                 Boolean       @default(false)
  platformConsentGiven     Boolean       @default(false)
  platformConsentTimestamp DateTime?
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt
  activityLogs             ActivityLog[]
  ownedLeads               Lead[]        @relation("LeadOwner")

  @@map("users")
}

model Lead {
  id                  String            @id @default(cuid())
  name                String
  email               String?
  phone               String?
  whatsappNumber      String?
  source              LeadSource        @default(WEBSITE_FORM)
  status              LeadStatus        @default(RAW)
  intent              LeadIntent        @default(UNSCORED)
  metadata            Json?
  aiScore             Int?
  aiScoredAt          DateTime?
  aiNotes             String?
  ownerId             String?           @db.Uuid
  assignedAt          DateTime?
  consentFlag         Boolean           @default(false)
  consentTimestamp    DateTime?
  consentMethod       String?
  dataRetentionExpiry DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  branchId            String?
  isAutoAssigned      Boolean           @default(false)
  category            TreatmentCategory @default(OTHER)
  aiChatStatus        AiChatStatus      @default(AGENTX_ACTIVE)
  isEscalated         Boolean           @default(false)
  activityLogs        ActivityLog[]
  autoNurtureQueue    AutoNurtureQueue?
  callLogs            CallLog[]
  owner               User?             @relation("LeadOwner", fields: [ownerId], references: [id])
  branch              Branch?           @relation(fields: [branchId], references: [id])

  @@index([branchId])
  @@index([ownerId])
  @@index([category])
  @@map("leads")
}

model AutoNurtureQueue {
  id           String    @id @default(cuid())
  leadId       String    @unique
  scheduledAt  DateTime  @default(now())
  nextFollowUp DateTime?
  attempt      Int       @default(0)
  isResolved   Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lead         Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([isResolved])
  @@map("auto_nurture_queue")
}

model ActivityLog {
  id          String   @id @default(cuid())
  leadId      String?
  userId      String?  @db.Uuid
  action      String
  description String?
  metadata    Json?
  createdAt   DateTime @default(now())
  lead        Lead?    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user        User?    @relation(fields: [userId], references: [id])

  @@map("activity_logs")
}

model CallLog {
  id           String        @id @default(cuid())
  leadId       String?
  direction    CallDirection
  status       CallStatus    @default(CONNECTED)
  duration     Int           @default(0)
  recordingUrl String?
  isQualified  Boolean       @default(false)
  isAiHandled  Boolean       @default(false)
  callerId     String
  receiverId   String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  lead         Lead?         @relation(fields: [leadId], references: [id])

  @@index([leadId])
  @@map("call_logs")
}

enum Industry {
  HEALTHCARE
  EDUCATION
  REAL_ESTATE
  FINANCE
  OTHER
}

enum LeadDistributionStrategy {
  ROUND_ROBIN
  MANUAL
}

enum OrgPlan {
  STARTER
  GROWTH
  ENTERPRISE
}

enum UserRole {
  SUPER_ADMIN
  ORG_ADMIN
  DOCTOR
  COUNSELOR
  MANAGER
  AGENT
  VIEWER
}

enum LeadSource {
  META_ADS
  GOOGLE_ADS
  WEBSITE_FORM
  WHATSAPP
  WALK_IN
  REFERRAL
  OTHER
  INSTAGRAM_ADS
  TIKTOK_ADS
  LINKEDIN_ADS
  MANUAL_ENTRY
  BULK_IMPORT
  META_MESSAGING
}

enum LeadStatus {
  RAW
  QUALIFIED
  CONTACTED
  APPOINTMENT_FIXED
  VISITED
  WON
  LOST
}

enum LeadIntent {
  HOT
  WARM
  COLD
  UNSCORED
}

enum TreatmentCategory {
  MATERNITY
  GYNECOLOGY
  INFERTILITY
  PEDIATRICS
  OTHER
}

enum CallDirection {
  INBOUND
  OUTBOUND
}

enum CallStatus {
  CONNECTED
  MISSED
  BUSY
  VOICEMAIL
  AI_HANDLED
}

enum AiChatStatus {
  AGENTX_ACTIVE
  HUMAN_OVERRIDE
}
